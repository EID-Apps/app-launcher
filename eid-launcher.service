[Unit]
Description=EID App Launcher
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/eid-apps/app-launcher
ExecStart=/opt/eid-apps/app-launcher/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
